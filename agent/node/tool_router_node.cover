    1: def ab_compare_routing(samples: list[dict[str, Any]], llm: Any = None) -> dict[str, Any]:
    1:     old_correct = 0
    1:     new_correct = 0
    1:     old_latency = 0.0
    1:     new_latency = 0.0
    1:     details: list[dict[str, Any]] = []
    7:     for item in samples:
    6:         query = str(item.get("query", ""))
    6:         expected = str(item.get("expected_mode", "hybrid_search"))
    6:         t0 = time.perf_counter()
    6:         old_mode = baseline_route_mode(query)
    6:         old_latency += time.perf_counter() - t0
    6:         t1 = time.perf_counter()
    6:         new_mode, triplet = refactored_route_mode(query, llm=llm)
    6:         new_latency += time.perf_counter() - t1
    6:         old_correct += 1 if old_mode == expected else 0
    6:         new_correct += 1 if new_mode == expected else 0
   12:         details.append(
    6:             {
    6:                 "query": query,
    6:                 "expected_mode": expected,
    6:                 "old_mode": old_mode,
    6:                 "new_mode": new_mode,
    6:                 "triplet": {
    6:                     "object_type": triplet.object_type,
    6:                     "color": triplet.color,
    6:                     "event_semantic": triplet.event_semantic,
    6:                     "event_kind": triplet.event_kind,
                       },
                   }
               )
    1:     total = max(len(samples), 1)
    1:     return {
    1:         "total": len(samples),
    1:         "old_accuracy": old_correct / total,
    1:         "new_accuracy": new_correct / total,
    1:         "old_avg_latency_ms": old_latency * 1000 / total,
    1:         "new_avg_latency_ms": new_latency * 1000 / total,
    1:         "improved_cases": new_correct - old_correct,
    1:         "details": details,
           }
       
       
    1: def create_tool_router_node(llm: Any = None):
    1:     def tool_router_node(state: AgentState, config: RunnableConfig, store: BaseStore) -> dict[str, Any]:
    4:         del config, store
    4:         is_new = StateResetter.is_new_query(state)
    4:         user_query = InputValidator.extract_latest_query(state)
    4:         reset_updates: dict[str, Any] = {}
    4:         if is_new:
                   reset_updates = StateResetter.reset_ephemeral_state(state, user_query)
    4:         if not user_query:
                   user_query = "未知查询"
    4:         mode, triplet = refactored_route_mode(user_query, llm=llm)
    4:         tool_choice: ToolChoice = {
    4:             "mode": mode,
    4:             "sql_needed": mode in ("pure_sql", "parallel"),
    4:             "hybrid_needed": mode in ("hybrid_search", "parallel", "hybrid"),
    4:             "video_vect_needed": False,
    4:             "sub_queries": {"sql": {}} if mode == "pure_sql" else {"hybrid": {}},
               }
    4:         parsed_question = dict(state.get("parsed_question", {}))
    8:         parsed_question.update({
    4:             "event": triplet.event_semantic,
    4:             "color": triplet.color,
    4:             "object_type": triplet.object_type,
    4:             "event_kind": triplet.event_kind,
               })
    4:         thought = (
    8:             f"tool_router_refactor: mode={mode}, video_vect={VIDEO_VECT_PLACEHOLDER}, "
    4:             f"triplet(object={triplet.object_type}, color={triplet.color}, kind={triplet.event_kind})"
               )
   12:         return {
    4:             **reset_updates,
    4:             "tool_choice": tool_choice,
    4:             "user_query": user_query,
    4:             "parsed_question": parsed_question,
    4:             "is_parallel": False,
    4:             "parallel_queries": [],
    4:             "thought": thought,
    4:             "messages": [AIMessage(content=f"工具路由完成: {mode}")],
    4:             "cot_context": [],
               }
    1:     return tool_router_node
       
       
    1: def _fallback_routing(user_query: str) -> Dict[str, Any]:
           mode, triplet = refactored_route_mode(user_query, llm=None)
           return {
               "mode": mode,
               "reason": f"fallback_refactor:{triplet.event_kind}",
               "confidence": 0.6,
               "video_vect_status": VIDEO_VECT_PLACEHOLDER,
           }
       
       
    1: def route_by_tool_choice(state: AgentState) -> str:
    1:     tool_choice = state.get("tool_choice", {})
    1:     mode = tool_choice.get("mode", "hybrid_search")
    1:     if mode in ("pure_sql", "sql"):
               return "pure_sql_preprocess"
    1:     return "hybrid_preprocess"
       
       
    1: def route_from_preprocess(state: AgentState) -> str:
    1:     tool_choice = state.get("tool_choice", {})
    1:     mode = tool_choice.get("mode", "hybrid_search")
    1:     if mode in ("pure_sql", "sql"):
