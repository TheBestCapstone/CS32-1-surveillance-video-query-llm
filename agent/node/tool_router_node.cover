    1: def _match_first_keyword(query: str, mapping: dict[str, list[str]]) -> str | None:
   72:     best: tuple[int, int, str] | None = None
  576:     for canonical, words in mapping.items():
 1764:         for w in words:
 1260:             idx = query.find(w)
 1260:             if idx < 0:
 1167:                 continue
   93:             key = (idx, -len(w), canonical)
   93:             if best is None or key < best:
   91:                 best = key
   72:     return best[2] if best is not None else None
       
       
    1: def _remove_known_tokens(query: str) -> str:
   35:     out = query
   35:     tokens: set[str] = set()
  245:     for words in OBJECT_SYNONYMS.values():
 1015:         tokens.update(str(w) for w in words)
  315:     for words in COLOR_SYNONYMS.values():
 1190:         tokens.update(str(w) for w in words)
 1260:     for token in sorted(tokens, key=len, reverse=True):
 1225:         out = out.replace(token, " ")
   35:     out = re.sub(r"\s+", " ", out).strip()
   35:     return out if out else query.strip()
       
       
    1: def _heuristic_event_semantic(query: str) -> str:
