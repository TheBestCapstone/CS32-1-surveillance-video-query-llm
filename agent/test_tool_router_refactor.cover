    2: class TestToolRouterRefactor(unittest.TestCase):
    1:     def test_video_vect_is_permanently_disabled(self):
    1:         router = create_tool_router_node()
    1:         cases = [
                   "Please do video semantic search",
                   "What happened in this scene",
                   "What targets are in the shot",
                   "Help me run video_vect",
               ]
    5:         for q in cases:
    4:             out = router({"user_query": q}, {}, None)
    4:             self.assertNotEqual(out["tool_choice"]["mode"], "video_vect")
    4:             self.assertFalse(out["tool_choice"]["video_vect_needed"])
    4:             self.assertIn(VIDEO_VECT_PLACEHOLDER, out["thought"])
       
